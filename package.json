{
  "name": "loop-apidoc-release-tools",
  "private": true,
  "scripts": {
    "tag:check": "git fetch --tags origin && tagsmith check",
    "tag:next": "git fetch --tags origin && tagsmith next",
    "tag:create": "git fetch --tags origin && tagsmith create --push",
    "release:prepare": "uv run python scripts/release.py prepare",
    "release:tag": "uv run python scripts/release.py tag"
  },
  "devDependencies": {
    "@carllee1983/tagsmith": "^0.3.1"
  }
}
